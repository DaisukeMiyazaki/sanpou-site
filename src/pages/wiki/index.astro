---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const base = import.meta.env.BASE_URL;
const features = (await getCollection('wiki')).sort((a, b) =>
	a.data.title.localeCompare(b.data.title),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Wiki | ${SITE_TITLE}`} description="Feature reference for Sanpou." />
		<style>
			main {
				width: 720px;
			}
			h1 {
				margin-bottom: 1em;
			}
			.wiki-list {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.wiki-list li {
				margin-bottom: 1.5em;
				padding: 1.2em 1.5em;
				background: white;
				border-radius: 12px;
				box-shadow: 0 2px 12px rgba(var(--gray), 12%);
				transition: transform 0.15s ease, box-shadow 0.15s ease;
			}
			.wiki-list li:hover {
				transform: translateY(-2px);
				box-shadow: 0 4px 20px rgba(var(--gray), 20%);
			}
			.wiki-list a {
				text-decoration: none;
				color: inherit;
			}
			.wiki-header {
				display: flex;
				align-items: center;
				gap: 0.6em;
				margin-bottom: 0.3em;
			}
			.version-badge {
				display: inline-block;
				background: var(--accent);
				color: white;
				padding: 0.15em 0.6em;
				border-radius: 6px;
				font-size: 0.75em;
				font-weight: 700;
			}
			.wiki-title {
				margin: 0;
				font-size: 1.2em;
			}
			.wiki-desc {
				color: rgb(var(--gray-dark));
				font-size: 0.9em;
				margin: 0;
			}
			.empty {
				color: rgb(var(--gray));
				font-style: italic;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>Wiki</h1>
			{features.length === 0 ? (
				<p class="empty">No feature pages yet.</p>
			) : (
				<ul class="wiki-list">
					{features.map((feature) => (
						<li>
							<a href={`${base}wiki/${feature.id}/`}>
								<div class="wiki-header">
									<span class="version-badge">v{feature.data.firstAddedVersion}</span>
									<h3 class="wiki-title">{feature.data.title}</h3>
								</div>
								<p class="wiki-desc">{feature.data.description}</p>
							</a>
						</li>
					))}
				</ul>
			)}
		</main>
		<Footer />
	</body>
</html>
