---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { APP_STORE_URL, SITE_DESCRIPTION, SITE_TITLE, SITE_TITLE_HOME, buildAppStoreUrl } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import Screenshot from '../components/Screenshot.astro';

const base = import.meta.env.BASE_URL;

const allPosts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featuredPost = allPosts.find((p) => p.id === 'ideas-born-outside-desk');
const latestPosts = allPosts.slice(0, 3);

const latestRelease = (await getCollection('releases'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())[0];

// schema.org MobileApplication — declares, machine-readably, that Sanpou is an
// iOS app (not the Japanese business-ethics concept 三方よし that the name
// otherwise collides with). Surfaced to crawlers and LLM-based analyzers.
const appStructuredData = {
	'@context': 'https://schema.org',
	'@graph': [
	{
	// WebSite — site identity, complementary to the app declaration below.
	'@type': 'WebSite',
	name: SITE_TITLE,
	url: new URL(base, Astro.site).href,
	description: SITE_DESCRIPTION,
	inLanguage: 'en',
	},
	{
	'@type': 'MobileApplication',
	name: 'Sanpou',
	// Japanese entity signals: the site copy is English, so add machine-readable
	// JP aliases + category keywords so AI search assistants (Gemini, etc.) and
	// crawlers can associate Sanpou with its Japanese category terms
	// (散歩メモ / ボイスメモアプリ). Entity understanding only — not visible meta.
	alternateName: ['散歩', 'さんぽ', '散歩メモ'],
	applicationCategory: 'LifestyleApplication',
	operatingSystem: 'iOS',
	inLanguage: ['en', 'ja'],
	keywords: '散歩メモ, ボイスメモ, 音声メモ, 散歩記録, ウォーキング日記, walking journal, voice memo, step tracking',
	description: SITE_DESCRIPTION,
	url: APP_STORE_URL,
	installUrl: APP_STORE_URL,
	offers: {
		'@type': 'Offer',
		price: '0',
		priceCurrency: 'USD',
	},
	},
	],
};
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE_HOME} description={SITE_DESCRIPTION} structuredData={appStructuredData} />
		<style>
			.hero {
				text-align: center;
				padding: 1em 1em 2em;
			}
			.story {
				max-width: 600px;
				margin: 0 auto;
				padding: 0 0 1em;
			}
			.story p {
				margin: 0 0 1.1em;
				color: rgb(var(--gray-dark));
				line-height: 1.85;
			}
			.story .lead {
				font-size: 1.25em;
				font-weight: 700;
				color: rgb(var(--black));
			}
			.visually-hidden {
				position: absolute;
				width: 1px;
				height: 1px;
				margin: -1px;
				padding: 0;
				overflow: hidden;
				clip: rect(0 0 0 0);
				white-space: nowrap;
				border: 0;
			}

			.featured-post {
				text-align: center;
				padding: 0 1em 2em;
			}
			.featured-post a {
				display: block;
				max-width: 540px;
				margin: 0 auto;
				background: linear-gradient(135deg, rgba(0,122,255,0.06), rgba(52,199,89,0.06));
				border: 1px solid rgba(0,122,255,0.15);
				border-radius: 12px;
				padding: 1.5em 2em;
				text-decoration: none;
				color: inherit;
				transition: transform 0.2s ease, box-shadow 0.2s ease;
			}
			.featured-post a:hover {
				transform: translateY(-2px);
				box-shadow: 0 4px 20px rgba(var(--gray), 20%);
			}
			.featured-post .featured-label {
				display: inline-block;
				font-size: 0.75em;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.05em;
				color: var(--accent);
				margin-bottom: 0.5em;
			}
			.featured-post h3 {
				font-size: 1.15em;
				margin: 0 0 0.4em;
			}
			.featured-post p {
				color: rgb(var(--gray));
				font-size: 0.9em;
				line-height: 1.5;
				margin: 0;
			}

			/* メモを取ったあとの体験を上から順に辿らせる。左右交互に置いて単調さを避ける */
			.journey {
				padding: 1em 0 2em;
			}
			.journey-step {
				display: flex;
				align-items: center;
				gap: 2em;
				margin-bottom: 3.5em;
			}
			.journey-step:nth-child(even) {
				flex-direction: row-reverse;
			}
			.journey-step p {
				flex: 1;
				margin: 0;
				font-size: 1.1em;
				line-height: 1.85;
				color: rgb(var(--gray-dark));
			}
			.journey-step :global(.screenshot) {
				flex: 0 0 190px;
				margin: 0;
			}
			/* JS が動くときだけ隠す。動かなければ最初から見えている */
			.journey.is-animated .journey-step,
			.journey.is-animated .journey-cta {
				opacity: 0;
				transform: translateY(14px);
				transition: opacity 0.5s ease, transform 0.5s ease;
			}
			.journey.is-animated .is-visible {
				opacity: 1;
				transform: none;
			}
			.journey-cta {
				text-align: center;
				padding-top: 0.5em;
			}
			.store-cta {
				display: inline-flex;
				align-items: center;
				gap: 0.5em;
				background: rgb(var(--black));
				color: white;
				padding: 0.75em 1.6em;
				border-radius: 12px;
				text-decoration: none;
				font-weight: 700;
			}
			.store-cta:hover {
				color: white;
				opacity: 0.85;
			}
			@media (max-width: 720px) {
				.journey-step,
				.journey-step:nth-child(even) {
					flex-direction: column;
					gap: 1em;
					margin-bottom: 2.5em;
					text-align: center;
				}
			}

			.section {
				padding: 2em 0;
			}
			.section-title {
				font-size: 1.8em;
				margin-bottom: 1em;
			}

			.latest-release {
				background: white;
				border-radius: 12px;
				padding: 1.5em 2em;
				box-shadow: 0 2px 12px rgba(var(--gray), 15%);
				margin-bottom: 2em;
			}
			.latest-release .version-badge {
				display: inline-block;
				background: var(--accent);
				color: white;
				padding: 0.2em 0.7em;
				border-radius: 6px;
				font-size: 0.8em;
				font-weight: 700;
				margin-bottom: 0.5em;
			}
			.latest-release h3 {
				margin-bottom: 0.3em;
			}
			.latest-release p {
				color: rgb(var(--gray));
				font-size: 0.9em;
				margin: 0;
			}
			.latest-release a {
				text-decoration: none;
				color: inherit;
			}

			.post-list {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.post-list li {
				padding: 1em 0;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.post-list li:last-child {
				border-bottom: none;
			}
			.post-list a {
				text-decoration: none;
				color: inherit;
			}
			.post-list h4 {
				margin: 0 0 0.2em;
				font-size: 1.1em;
			}
			.post-list .date {
				color: rgb(var(--gray));
				font-size: 0.8em;
			}
			.post-list .description {
				color: rgb(var(--gray));
				font-size: 0.85em;
				margin: 0.3em 0 0;
			}
			.post-list a:hover h4 {
				color: var(--accent);
			}

			.view-all {
				display: inline-block;
				margin-top: 1em;
				color: var(--accent);
				text-decoration: none;
				font-weight: 600;
			}
			.view-all:hover {
				text-decoration: underline;
			}

		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<!-- 見出しはヒーローカット内のキャッチコピーが担うが、SEO と読み上げのために h1 は残す -->
				<h1 class="visually-hidden">{SITE_TITLE_HOME}</h1>
				<Screenshot name="hero" variant="framed" size="lg" alt="Life is busy. Ideas slip away fast. Sanpou can help." />
			</section>

			<section class="story">
				<p class="lead">You have so many ideas. You just haven&rsquo;t noticed them yet.</p>
				<p>
					Because in 2026, the most precious thing you own is your focus &mdash; and everyone
					out there is fighting for one more millimeter of it.
				</p>
				<p>
					You don&rsquo;t want to shut yourself off. You want to be here, in this moment. But by
					the time you look up, the idea is already gone. In 2026, the thoughts you don&rsquo;t
					want to forget are the ones that weigh on you.
				</p>
				<p>
					All it takes is one tap. Stash it in a second, and come back to now. Nothing left to
					carry. You&rsquo;re allowed to forget &mdash; being able to forget is happiness.
				</p>
			</section>

			<section class="journey">
				<div class="journey-step">
					<Screenshot name="lockscreen" variant="raw" size="sm" alt="Sanpou widget on the lock screen" />
					<p>One tap from the lock screen &mdash; you&rsquo;re recording before you&rsquo;ve even unlocked your phone.</p>
				</div>
				<div class="journey-step">
					<Screenshot name="memo-input" variant="raw" size="sm" alt="Writing a memo" />
					<p>Say it out loud, or type it if the street is noisy. Either way, it takes a second.</p>
				</div>
				<div class="journey-step">
					<Screenshot name="memo-list" variant="raw" size="sm" alt="Memos saved with time, place and steps" />
					<p>It&rsquo;s kept with everything around it: the time, the place, the steps you had already walked.</p>
				</div>
				<div class="journey-step">
					<Screenshot name="map" variant="raw" size="sm" alt="Memos pinned on a map" />
					<p>Weeks later, your ideas have a geography. You start to see where your thinking actually happens.</p>
				</div>
				<div class="journey-step">
					<Screenshot name="ocr" variant="raw" size="sm" alt="Reading text from a photo" />
					<p>Words on a sign, a menu, a page &mdash; they come along too, straight into the memo.</p>
				</div>
				<div class="journey-step">
					<Screenshot name="presentations" variant="raw" size="sm" alt="A walk replayed as a slideshow" />
					<p>A walk comes back to you as a slideshow. You remember the day, not just the note.</p>
				</div>
				<div class="journey-step">
					<p>And none of it is locked in. Send it to Obsidian, Notion, or plain Markdown &mdash; it was always yours.</p>
				</div>
				<div class="journey-cta">
					<a href={buildAppStoreUrl('site-story')} class="store-cta" target="_blank" rel="noopener noreferrer" data-app-store-link="story">
						<svg viewBox="0 0 24 24" aria-hidden="true" width="22" height="22">
							<path fill="currentColor" d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
						</svg>
						Download on the App Store
					</a>
				</div>
			</section>

			{featuredPost && (
				<section class="featured-post">
					<a href={`${base}blog/${featuredPost.id}/`}>
						<span class="featured-label">Featured</span>
						<h3>{featuredPost.data.title}</h3>
						<p>{featuredPost.data.description}</p>
					</a>
				</section>
			)}

			{latestRelease && (
				<section class="section">
					<h2 class="section-title">Latest Release</h2>
					<div class="latest-release">
						<a href={`${base}releases/${latestRelease.id}/`}>
							<span class="version-badge">v{latestRelease.data.version}</span>
							<h3>{latestRelease.data.title}</h3>
							<p>{latestRelease.data.description}</p>
						</a>
					</div>
					<a href={`${base}releases`} class="view-all">All releases &rarr;</a>
				</section>
			)}

			{latestPosts.length > 0 && (
				<section class="section">
					<h2 class="section-title">From the Blog</h2>
					<ul class="post-list">
						{latestPosts.map((post) => (
							<li>
								<a href={`${base}blog/${post.id}/`}>
									<h4>{post.data.title}</h4>
									<span class="date"><FormattedDate date={post.data.pubDate} /></span>
									<p class="description">{post.data.description}</p>
								</a>
							</li>
						))}
					</ul>
					<a href={`${base}blog`} class="view-all">All posts &rarr;</a>
				</section>
			)}
		</main>
		<Footer />
		<script>
			// 各段が画面に入ったら軽くフェードインさせる。
			// 動きを減らす設定のときと JS が動かないときは、そのまま表示する。
			const journey = document.querySelector('.journey');
			const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
			if (journey && !reduced) {
				journey.classList.add('is-animated');
				const observer = new IntersectionObserver(
					(entries) => {
						for (const entry of entries) {
							if (!entry.isIntersecting) continue;
							entry.target.classList.add('is-visible');
							observer.unobserve(entry.target);
						}
					},
					{ rootMargin: '0px 0px -10% 0px' },
				);
				for (const step of journey.querySelectorAll('.journey-step, .journey-cta')) {
					observer.observe(step);
				}
			}
		</script>
	</body>
</html>
