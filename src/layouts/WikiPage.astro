---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import Screenshot from '../components/Screenshot.astro';
import { SITE_TITLE } from '../consts';

type Props = CollectionEntry<'wiki'>['data'];

const base = import.meta.env.BASE_URL;
const { title, description, firstAddedVersion, lastUpdated, screenshot } = Astro.props;

const pageURL = new URL(Astro.url.pathname, Astro.site).href;
const homeURL = new URL(base, Astro.site).href;
const wikiURL = new URL(`${base}wiki`, Astro.site).href;
const publisher = { '@type': 'Organization', name: SITE_TITLE, url: homeURL };

const structuredData = {
	'@context': 'https://schema.org',
	'@graph': [
		{
			'@type': 'TechArticle',
			headline: title,
			description,
			dateModified: lastUpdated.toISOString(),
			author: publisher,
			publisher,
			mainEntityOfPage: pageURL,
		},
		{
			'@type': 'BreadcrumbList',
			itemListElement: [
				{ '@type': 'ListItem', position: 1, name: 'Home', item: homeURL },
				{ '@type': 'ListItem', position: 2, name: 'Features', item: wikiURL },
				{ '@type': 'ListItem', position: 3, name: title, item: pageURL },
			],
		},
	],
};
---

<html lang="en">
	<head>
		<BaseHead title={`${title} | Sanpou`} description={description} structuredData={structuredData} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.3em 0;
			}
			.version-badge {
				display: inline-block;
				background: var(--accent);
				color: white;
				padding: 0.2em 0.7em;
				border-radius: 6px;
				font-size: 0.7em;
				font-weight: 700;
				margin-bottom: 0.5em;
			}
			.meta {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
				font-size: 0.85em;
			}
			.back-link {
				display: inline-block;
				margin-top: 2em;
				color: var(--accent);
				text-decoration: none;
				font-weight: 600;
			}
			.back-link:hover {
				text-decoration: underline;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="prose">
					<div class="title">
						<span class="version-badge">Since v{firstAddedVersion}</span>
						<div class="meta">
							Last updated <FormattedDate date={lastUpdated} />
						</div>
						<h1>{title}</h1>
						<hr />
					</div>
					{screenshot && <Screenshot name={screenshot} variant="raw" size="md" alt={`${title} screen`} />}
					<slot />
					<a href={`${base}wiki`} class="back-link">&larr; All features</a>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
